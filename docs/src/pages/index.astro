---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<BaseLayout>
  <main>
    <h1>Receipt-First Portfolio</h1>
    <p class="value-prop">Every project here ships with a measurable result — no vague outcomes, only hard numbers.</p>

    <div class="grid">
      {projects.map((project) => (
        <a href={`${import.meta.env.BASE_URL}/projects/${project.slug}`} class="card-link">
          <article class="card">
            <img
              src={project.data.coverImage}
              alt={project.data.title}
              class="card-image"
            />
            <div class="card-body">
              <p class="card-title">{project.data.title}</p>
              <p class="card-tagline">{project.data.tagline}</p>
              <span class="receipt-badge">{project.data.receipt}</span>
            </div>
          </article>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .value-prop {
    max-width: 640px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  @media (min-width: 768px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }

    /* Center lone card when 3 items produce an orphaned last row */
    .grid > .card-link:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      max-width: calc(50% - var(--space-2));
      margin-left: auto;
      margin-right: auto;
    }
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .card-link:hover {
    opacity: 0.7;
  }

  .card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-2);
    background: var(--color-bg);
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--color-border);
    border-radius: var(--radius);
    display: block;
  }

  .card-body {
    padding-top: var(--space-2);
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: var(--space-1);
  }

  .card-tagline {
    font-size: 1rem;
    margin-bottom: var(--space-2);
  }

  .receipt-badge {
    display: inline-block;
    background: #ffffff;
    color: #1a1a1a;
    font-weight: bold;
    border: 1px solid #cccccc;
    border-radius: var(--space-1);
    padding: var(--space-1) var(--space-2);
    font-size: 0.875rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }
</style>
